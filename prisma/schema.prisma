generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pengeluaran {
  id         Int      @id @default(autoincrement())
  namaBarang String
  harga      Float
  jumlah     Int
  tanggal    String
  kategori   String
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tanggal, isDeleted])
  @@map("pengeluaran")
}

model KeranjangBelanja {
  id              Int      @id @default(autoincrement())
  namaProduk      String
  perkiraanHarga  Float
  ukuranIsi       Float
  isChecked       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("keranjang_belanja")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  photoUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  posts        Post[]

  @@map("users")
}

model Post {
  id           Int      @id @default(autoincrement())
  text         String
  imageUrl     String?
  imageDataUrl String?
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, createdAt])
  @@map("posts")
}
